class Array {

    public int[] add(int a, int b, int c){
        int[] array;

        array[0] = a;
        array[1] = b;
        array[2] = b;
        array[3] = a + b + c;

        return array;
    }


    public static void main(String[] args){
        int d;
        int b;
        int c;
        int result;
        int[] a;
        Simple s;

        d = 1;
        b = 2;
        c = 3;
        s = new Array();

        a = s.add(d, b, c);

        result = a[3];

        ioPlus.printResult(result);
    }
}